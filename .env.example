# OpenEnv Inference Script Configuration

# The base URL for the LLM API. 
# Used by the evaluation harness to swap in varying models.
API_BASE_URL=https://router.huggingface.co/v1

# The open-weight model used to drive the agent
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# Hugging Face / API token assigned by the evaluation harness
HF_TOKEN=hf_your_token_here
